{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://portfolio-hrz.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://portfolio-hrz.onrender.com/uploads/$1"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
